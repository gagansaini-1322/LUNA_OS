# Luna OS — controller auto-detection
# config/includes.chroot/etc/udev/rules.d/70-luna-controllers.rules
#
# Ensures gamepads are usable by the logged-in user with zero manual setup.
# xpad (Xbox controllers) is handled by the kernel module already in the
# gaming package list; these rules just fix up permissions/tagging.

# Generic joystick/gamepad class devices — readable/writable by the seat
SUBSYSTEM=="input", ATTRS{bInterfaceClass}=="03", ENV{ID_INPUT_JOYSTICK}="1"
KERNEL=="js[0-9]*", SUBSYSTEM=="input", MODE="0664", TAG+="uaccess"
KERNEL=="event[0-9]*", SUBSYSTEM=="input", ENV{ID_INPUT_JOYSTICK}=="1", MODE="0664", TAG+="uaccess"

# Xbox 360 / Xbox One controllers (xpad)
SUBSYSTEM=="usb", ATTRS{idVendor}=="045e", MODE="0664", TAG+="uaccess"

# Sony PS3 (sixaxis/DS3) and PS4 (DS4) controllers
SUBSYSTEM=="usb", ATTRS{idVendor}=="054c", MODE="0664", TAG+="uaccess"
SUBSYSTEM=="bluetooth", ATTRS{idVendor}=="054c", MODE="0664", TAG+="uaccess"

# Generic HID gamepads (covers most third-party USB controllers)
SUBSYSTEM=="hidraw", ATTRS{bInterfaceClass}=="03", MODE="0664", TAG+="uaccess"
