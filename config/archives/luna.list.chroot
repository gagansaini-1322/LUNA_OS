# Luna OS — explicit apt sources for the chroot
# config/archives/luna.list.chroot
#
# Belt-and-suspenders alongside auto/config's --archive-areas: this
# guarantees main/contrib/non-free/non-free-firmware are all enabled
# even if --archive-areas behaves differently across live-build versions.

deb https://deb.debian.org/debian bookworm main contrib non-free non-free-firmware
deb https://deb.debian.org/debian-security bookworm-security main contrib non-free non-free-firmware
deb https://deb.debian.org/debian bookworm-updates main contrib non-free non-free-firmware
