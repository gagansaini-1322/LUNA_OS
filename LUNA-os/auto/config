#!/bin/sh
set -e

# Luna OS — live-build configuration
# Debian Bookworm, amd64, hybrid ISO, dual BIOS/UEFI boot, persistence-ready
#
# live-build renamed --bootloader -> --bootloaders at some point between
# releases; older installs (common on Debian bookworm hosts) only accept
# the singular form. Detect which one this install supports instead of
# hardcoding it.

if lb config --help 2>&1 | grep -q -- '--bootloaders'; then
    BOOTLOADER_OPT="--bootloaders"
else
    BOOTLOADER_OPT="--bootloader"
fi

# NOTE: no --linux-flavours here. live-build's flavour->package-name
# mapping is unreliable across versions/distros (it produced the
# nonexistent "linux-image-lowlatency", which is an Ubuntu name anyway).
# Instead, the real-time kernel (linux-image-rt-amd64) is listed directly
# in config/package-lists/luna.list.chroot.

lb config noauto \
    --architectures amd64 \
    --distribution bookworm \
    --binary-images iso-hybrid \
    --archive-areas "main contrib non-free non-free-firmware" \
    "$BOOTLOADER_OPT" "grub-pc grub-efi" \
    --bootappend-live "boot=live components persistence splash quiet" \
    --iso-application "Luna OS" \
    --iso-publisher "Luna OS Project" \
    --iso-volume "LUNA-OS" \
    --memtest none \
    --win32-loader false \
    --apt-recommends false \
    --apt-source-archives false \
    --cache-packages false \
    "${@}"
