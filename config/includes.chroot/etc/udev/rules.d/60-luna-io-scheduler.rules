# Luna OS — I/O scheduler tuning by device type
# config/includes.chroot/etc/udev/rules.d/60-luna-io-scheduler.rules

# USB-backed boot media (the live USB itself, and any USB storage)
ACTION=="add|change", KERNEL=="sd[a-z]", ATTRS{removable}=="1", ATTR{queue/scheduler}="mq-deadline"

# Rotational HDDs
ACTION=="add|change", KERNEL=="sd[a-z]", ATTR{queue/rotational}=="1", ATTRS{removable}!="1", ATTR{queue/scheduler}="bfq"

# NVMe SSDs — hardware queueing makes scheduling overhead counterproductive
ACTION=="add|change", KERNEL=="nvme[0-9]n[0-9]", ATTR{queue/scheduler}="none"

# Non-rotational SATA/USB SSDs that aren't the boot media
ACTION=="add|change", KERNEL=="sd[a-z]", ATTR{queue/rotational}=="0", ATTRS{removable}!="1", ATTR{queue/scheduler}="mq-deadline"
